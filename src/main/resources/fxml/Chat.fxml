<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.ChatController"
            stylesheets="@../css/owner-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="240" styleClass="owner-sidebar" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="logo-container">
                <StackPane styleClass="logo-icon-bg">
                    <Label text="🏠" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="PGFinder" styleClass="owner-logo"/>
                    <Label text="Owner Panel" styleClass="owner-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="20"/>

            <Button text="📁  Dashboard" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="🏢 My PGs" styleClass="owner-menu" maxWidth="Infinity" onAction="#openMyPGs"/>
            <Button text="🛏  Rooms &amp; Beds" styleClass="owner-menu" maxWidth="Infinity" onAction="#openRoomsBeds"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="📋  Requests" styleClass="owner-menu" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openBookingRequests"/>
                <Label fx:id="pendingBadgeLabel" text="0" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="👥  Tenants" styleClass="owner-menu" maxWidth="Infinity" onAction="#openTenants"/>
            <Button text="📢  Announcements" styleClass="owner-menu" maxWidth="Infinity" onAction="#openAnnouncements"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="💬  Chats" styleClass="owner-menu-active" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openChat"/>
                <Label fx:id="chatBadgeLabel" text="0" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="⭐  Reviews" styleClass="owner-menu" maxWidth="Infinity" onAction="#openReviews"/>
            <Button text="📊  Reports" styleClass="owner-menu" maxWidth="Infinity" onAction="#openReports"/>
            <Button text="⚙  Settings" styleClass="owner-menu" maxWidth="Infinity" onAction="#openSettings"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="↪  Logout" styleClass="logout-button" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- MAIN CHAT WORKSPACE -->
    <center>
        <HBox spacing="0" styleClass="main-scrollpane">
            
            <!-- CONVERSATIONS LIST SIDEBAR (LEFT COLUMN OF CHAT) -->
            <VBox prefWidth="280" styleClass="chat-sidebar" spacing="12">
                <Label text="Direct Messages" styleClass="sidebar-title"/>
                <TextField promptText="Search tenant conversations..." styleClass="text-field" style="-fx-font-size: 12px;"/>
                
                <Separator/>
                
                <VBox fx:id="conversationsContainer" spacing="6"/>
            </VBox>

            <!-- CHAT VIEWPORT (RIGHT COLUMN OF CHAT) -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-padding: 20; -fx-background-color: #FFFFFF;">
                
                <!-- Chat Header Info -->
                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="owner-large-card" style="-fx-padding: 12 18; -fx-effect: none; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1px 0; -fx-border-radius: 0;">
                    <StackPane styleClass="avatar-circle" style="-fx-min-width: 32px; -fx-max-width: 32px; -fx-min-height: 32px; -fx-max-height: 32px;">
                        <Label text="RS" styleClass="avatar-text"/>
                    </StackPane>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="chatPartnerLabel" text="Select a tenant" styleClass="chat-name" style="-fx-font-size: 15px;"/>
                        <Label text="Active staying tenant in Room A1, Bed B1" styleClass="stat-sublabel"/>
                    </VBox>
                </HBox>

                <!-- Messages area -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #F9FAFB; -fx-padding: 10;">
                    <VBox fx:id="messagesContainer" spacing="15" styleClass="messages-area"/>
                </ScrollPane>

                <!-- Message input footer -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="messageInput" promptText="Type your reply to Rahul..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
                    <Button text="Send Reply" styleClass="send-button" onAction="#handleSendMessage"/>
                </HBox>
                
            </VBox>

        </HBox>
    </center>

</BorderPane>