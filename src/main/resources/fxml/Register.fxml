<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pgfinder.controller.RegisterController" prefHeight="450.0" prefWidth="600.0">
    <children>
        <Label text="Register Screen" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <TextField fx:id="nameField" promptText="Name" maxWidth="250.0"/>
        <TextField fx:id="emailField" promptText="Email" maxWidth="250.0"/>
        <PasswordField fx:id="passwordField" promptText="Password" maxWidth="250.0"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="250.0"/>
        <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="250.0"/>
        <TextField fx:id="phoneField" promptText="Phone Number" maxWidth="250.0"/>
        <Button fx:id="registerButton" text="Register" onAction="#handleRegister"/>
        <Label fx:id="errorLabel" text="" textFill="RED"/>
        <Hyperlink fx:id="goToLoginLink" text="Already have an account? Login" onAction="#handleGoToLogin"/>
    </children>
</VBox>
