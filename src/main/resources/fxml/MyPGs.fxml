<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.MyPGsController"
            stylesheets="@../css/owner-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
<left>
    <VBox prefWidth="240" styleClass="owner-sidebar" spacing="8">

        <HBox alignment="CENTER_LEFT"
              spacing="12"
              styleClass="logo-container">

            <StackPane styleClass="logo-icon-bg">
                <Label text="🏠" styleClass="logo-icon"/>
            </StackPane>

            <VBox>
                <Label text="PGFinder" styleClass="owner-logo"/>
                <Label text="Owner Panel" styleClass="owner-subtitle"/>
            </VBox>

        </HBox>

        <Region prefHeight="20"/>

        <Button
                text="📁 Dashboard"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openDashboard"/>

        <Button
                text="🏢 My PGs"
                styleClass="owner-menu-active"
                maxWidth="Infinity"/>

        <!-- Removed onAction intentionally -->
        <Button
                text="🛏 Rooms &amp; Beds"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openRoomsBeds"/>

        <HBox alignment="CENTER_LEFT"
              styleClass="menu-item-with-badge">

            <Button
                    text="📋 Requests"
                    styleClass="owner-menu"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    onAction="#openBookingRequests"/>

            <Label
                    text="5"
                    styleClass="menu-badge"/>

        </HBox>

        <Button
                text="👥 Tenants"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openTenants"/>

        <Button
                text="📢 Announcements"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openAnnouncements"/>

        <HBox alignment="CENTER_LEFT"
              styleClass="menu-item-with-badge">

            <Button
                    text="💬 Chats"
                    styleClass="owner-menu"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    onAction="#openChat"/>

            <Label
                    text="3"
                    styleClass="menu-badge"/>

        </HBox>

        <Button
                text="⭐ Reviews"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openReviews"/>

        <Button
                text="📊 Reports"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openReports"/>

        <Button
                text="⚙ Settings"
                styleClass="owner-menu"
                maxWidth="Infinity"
                onAction="#openSettings"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Button
                text="↪ Logout"
                styleClass="logout-button"
                maxWidth="Infinity"
                onAction="#handleLogout"/>

    </VBox>
</left>

    <!-- MAIN BODY -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scrollpane">
            <VBox spacing="25" styleClass="owner-main-content">
                
                <!-- HEADER & ACTION -->
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Manage Properties" styleClass="welcome-title"/>
                        <Label text="View, edit, and add rooms for your PG buildings." styleClass="welcome-subtitle"/>
                    </VBox>
                    <Button fx:id="registerPGButton" text="+ Register New PG" onAction="#handleRegisterNewPG" styleClass="primary-button" style="-fx-font-size: 13px; -fx-padding: 10 20;"/>
                </HBox>

                <!-- STATS SUMMARY -->
                <GridPane hgap="20" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.3"/>
                        <ColumnConstraints percentWidth="33.3"/>
                        <ColumnConstraints percentWidth="33.3"/>
                    </columnConstraints>
                    
                    <HBox styleClass="owner-stat-card" GridPane.columnIndex="0" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container"><Label text="🏢" styleClass="stat-icon"/></StackPane>
                        <VBox>
                            <Label text="Properties Managed" styleClass="stat-label"/>
                            <Label fx:id="totalPgsLabel" text="0 PGs" styleClass="owner-stat-number"/>
                        </VBox>
                    </HBox>

                    <HBox styleClass="owner-stat-card" GridPane.columnIndex="1" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container"><Label text="🛏" styleClass="stat-icon"/></StackPane>
                        <VBox>
                            <Label text="Total Rooms Capacity" styleClass="stat-label"/>
                            <Label fx:id="totalRoomsLabel" text="0 Rooms" styleClass="owner-stat-number"/>
                        </VBox>
                    </HBox>

                    <HBox styleClass="owner-stat-card" GridPane.columnIndex="2" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container"><Label text="📈" styleClass="stat-icon"/></StackPane>
                        <VBox>
                            <Label text="Average Occupancy" styleClass="stat-label"/>
                            <Label fx:id="avgOccupancyLabel" text="0%" styleClass="owner-stat-number" style="-fx-text-fill: #0F4F46;"/>
                        </VBox>
                    </HBox>
                </GridPane>

               <!-- PROPERTY CARDS LIST -->

                    <VBox spacing="15">

                        <HBox alignment="CENTER_LEFT">
                             <Label text="Your Properties" styleClass="section-title"/>
                             <Region HBox.hgrow="ALWAYS"/>
                             <Label fx:id="propertyCountLabel" text="0 Properties" styleClass="welcome-subtitle"/>
                        </HBox>

                     <!-- Dynamic PG Cards -->
                        <VBox fx:id="pgsContainer" spacing="20"/>
                    </VBox>
            </VBox>

        </ScrollPane>
    </center>
</BorderPane>