<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.MyPGsController"
             stylesheets="@/css/owner-dashboard.css,@/css/my-pgs.css"
            prefWidth="1280" prefHeight="800" >

  
            
           

    <left>

        <VBox styleClass="sidebar-container"
              prefWidth="248">

            <!-- Brand -->
            <HBox spacing="14"
                  alignment="CENTER_LEFT"
                  styleClass="sidebar-header">

                <StackPane styleClass="sidebar-logo-badge">
                    <Label text="🏠"
                           styleClass="sidebar-logo-icon"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="PGFinder"
                           styleClass="sidebar-brand-title"/>
                    <Label text="Owner Panel"
                           styleClass="sidebar-brand-subtitle"/>
                </VBox>

            </HBox>

           <Separator styleClass="sidebar-divider"/>

<VBox spacing="6"
      alignment="CENTER"
      styleClass="owner-profile-section">

    <StackPane styleClass="owner-avatar-container">

        <ImageView fx:id="ownerProfileImage"
                   fitWidth="72"
                   fitHeight="72"
                   preserveRatio="true"
                   styleClass="owner-avatar"/>

    </StackPane>

    <Label fx:id="ownerNameLabel"
           text="Owner"
           styleClass="owner-profile-name"/>

   <Label
    fx:id="ownerEmailLabel"
    text="Property Owner"
    styleClass="owner-profile-email"/>


</VBox>

<Separator styleClass="sidebar-divider"/>

<Region prefHeight="12"/>



            <!-- Nav items -->
            <Button text="📊  Dashboard"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openDashboard"/>

            <Button text="🏢  My PGs"
                    styleClass="menu-btn-active"
                    maxWidth="Infinity"/>

            <Button text="🛏  Rooms &amp; Beds"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openRoomsBeds"/>

            <Button text="📋  Booking Requests"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openBookingRequests"/>

            <Button text="👥  Tenants"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openTenants"/>

            <Button text="📢  Announcements"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openAnnouncements"/>

            <Button text="⭐  Reviews"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openReviews"/>

            <Button text="💬  Chat"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openChat"/>

            <Button text="⚙  Settings"
                    styleClass="menu-btn"
                    maxWidth="Infinity"
                    onAction="#openSettings"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator styleClass="sidebar-divider"/>
            <Region prefHeight="8"/>

            <Button text="🚪  Logout"
                    styleClass="menu-logout-btn"
                    maxWidth="Infinity"
                    onAction="#handleLogout"/>

        </VBox>

    </left>


    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="content-scrollpane">
        <StackPane>    
            <VBox spacing="34" styleClass="main-content-vbox">
                
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                       <Label text="My PGs" styleClass="page-title"/>
                       <Label text="Manage all your properties and their details." styleClass="page-subtitle"/>
                    </VBox>
                    <Button fx:id="registerPGButton" text="+ Register New PG" onAction="#handleRegisterNewPG" styleClass="primary-btn"/>
                </HBox>

                <HBox spacing="20">
                    <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <StackPane styleClass="kpi-card-icon">
                                <Label text="🏢"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Properties Managed" styleClass="kpi-hero-label"/>
                                <Label fx:id="totalPgsLabel" text="0 PGs" styleClass="kpi-hero-value"/>
                                <Label text="PGs" styleClass="kpi-trend-text"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <StackPane styleClass="kpi-card-icon">
                                <Label text="🛏" styleClass="kpi-label"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Total Rooms Capacity" styleClass="kpi-hero-label"/>
                                <Label fx:id="totalRoomsLabel" text="0 Rooms" styleClass="kpi-hero-value"/>
                                <Label text="Rooms" styleClass="kpi-trend-text"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <StackPane styleClass="kpi-card-icon">
                                <Label text="📈" styleClass="kpi-label"/>
                            </StackPane>
                            <VBox spacing="2">
                                <Label text="Average Occupancy" styleClass="kpi-hero-label"/>
                                <Label fx:id="avgOccupancyLabel" text="0%" styleClass="kpi-hero-value"/>
                                <Label text="Across all properties" styleClass="kpi-trend-text"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox spacing="20" styleClass="section-card">
                    <HBox alignment="CENTER_LEFT">

                        <Label text="Your Properties" styleClass="section-card-title"/>
                            <Region HBox.hgrow="ALWAYS"/>

                    </HBox>
                    <VBox fx:id="pgsContainer" spacing="20"/>
                </VBox>

            </VBox>
        </StackPane>

        </ScrollPane>
    </center>
</BorderPane> 