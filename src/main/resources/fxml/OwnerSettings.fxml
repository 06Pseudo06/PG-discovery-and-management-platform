<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.SettingsController"
            stylesheets="@../css/owner-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="240" styleClass="owner-sidebar" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="logo-container">
                <StackPane styleClass="logo-icon-bg">
                    <Label text="🏠" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="PGFinder" styleClass="owner-logo"/>
                    <Label text="Owner Panel" styleClass="owner-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="20"/>

            <Button text="📁  Dashboard" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="🏢 My PGs" styleClass="owner-menu" maxWidth="Infinity" onAction="#openMyPGs"/>
            <Button text="🛏  Rooms &amp; Beds" styleClass="owner-menu" maxWidth="Infinity" onAction="#openRoomsBeds"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="📋  Requests" styleClass="owner-menu" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openBookingRequests"/>
                <Label text="5" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="👥  Tenants" styleClass="owner-menu" maxWidth="Infinity" onAction="#openTenants"/>
            <Button text="📢  Announcements" styleClass="owner-menu" maxWidth="Infinity" onAction="#openAnnouncements"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="💬  Chats" styleClass="owner-menu" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openChat"/>
                <Label text="3" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="⭐  Reviews" styleClass="owner-menu" maxWidth="Infinity" onAction="#openReviews"/>
            <Button text="📊  Reports" styleClass="owner-menu" maxWidth="Infinity" onAction="#openReports"/>
            <Button text="⚙  Settings" styleClass="owner-menu-active" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="↪  Logout" styleClass="logout-button" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="25" styleClass="owner-main-content" style="-fx-padding: 30 50;">
                
                <!-- HEADER -->
                <VBox spacing="5">
                    <Label text="Account Settings" styleClass="welcome-title" style="-fx-font-size: 28px;"/>
                    <Label text="Manage your profile information, password, and system configurations." styleClass="welcome-subtitle"/>
                </VBox>

                <!-- SETTINGS CONTROLS -->
                <VBox spacing="25" maxWidth="800">
                    
                    <!-- PROFILE SETTINGS -->
                    <VBox spacing="15" styleClass="owner-large-card">
                        <Label text="Profile Information" styleClass="section-title"/>
                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30"/>
                                <ColumnConstraints percentWidth="70"/>
                            </columnConstraints>
                            
                            <Label text="Full Name" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="nameField" text="Alex" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            
                            <Label text="Email Address" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="emailField" text="alex@pgfinder.com" GridPane.rowIndex="1" GridPane.columnIndex="1" editable="false" style="-fx-background-color: #F3F4F6;"/>
                            
                            <Label text="Phone Number" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <TextField fx:id="phoneField" text="+91 98765 43210" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            
                            <Label text="Profile Picture" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <HBox spacing="15" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                                <ImageView fx:id="profileImageView" fitWidth="60" fitHeight="60" preserveRatio="true"/>
                                <VBox spacing="5">
                                    <Button text="Upload Picture" onAction="#handleUploadImage" styleClass="btn-outline" style="-fx-font-size: 11px;"/>
                                    <Button text="Delete Picture" onAction="#handleDeleteImage" styleClass="quick-action-btn" style="-fx-font-size: 11px; -fx-text-fill: white; -fx-background-color: #EF4444;"/>
                                </VBox>
                            </HBox>
                        </GridPane>
                        <Separator/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Save Profile Info" styleClass="quick-action-btn" onAction="#handleSaveProfile"/>
                        </HBox>
                    </VBox>

                    <!-- SECURITY / PASSWORD SETTINGS -->
                    <VBox spacing="15" styleClass="owner-large-card">
                        <Label text="Security &amp; Password" styleClass="section-title"/>
                        <GridPane hgap="20" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="30"/>
                                <ColumnConstraints percentWidth="70"/>
                            </columnConstraints>
                            
                            <Label text="Current Password" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="currentPasswordField" promptText="Enter current password" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            
                            <Label text="New Password" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="newPasswordField" promptText="Enter new password" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            
                            <Label text="Confirm Password" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        </GridPane>
                        <Separator/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Change Password" styleClass="btn-outline" onAction="#handleChangePassword"/>
                        </HBox>
                    </VBox>

                    <!-- PREFERENCES & NOTIFICATIONS -->
                    <VBox spacing="15" styleClass="owner-large-card">
                        <Label text="Preferences &amp; Notifications" styleClass="section-title"/>
                        <VBox spacing="12">
                            <CheckBox fx:id="emailNotificationsToggle" text="Receive email notifications for announcements" selected="true"/>
                            <CheckBox fx:id="chatNotificationsToggle" text="Receive notifications for new chat messages" selected="true"/>
                            <Separator style="-fx-padding: 5 0;"/>
                            <HBox alignment="CENTER_LEFT" spacing="20">
                                <Label text="Theme Preference" style="-fx-font-weight: bold;"/>
                                <ToggleButton fx:id="themeToggleButton" text="Light Mode Active" styleClass="btn-secondary" onAction="#handleToggleTheme"/>
                                <Label text="(Dark Mode support placeholder)" styleClass="welcome-subtitle" style="-fx-font-size: 11px;"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- DANGER ZONE -->
                    <VBox spacing="15" styleClass="owner-large-card" style="-fx-border-color: #FCA5A5; -fx-border-width: 1.5px;">
                        <Label text="Danger Zone" styleClass="section-title" style="-fx-text-fill: #DC2626;"/>
                        <Label text="Actions here can permanently log you out or delete your application data." styleClass="welcome-subtitle" style="-fx-font-size: 13px;"/>
                        <HBox spacing="15">
                            <Button text="Log Out" styleClass="btn-secondary" onAction="#handleLogout"/>
                            <Button text="Delete Account" styleClass="quick-action-btn" style="-fx-background-color: #EF4444; -fx-text-fill: white;" onAction="#handleDeleteAccount"/>
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
