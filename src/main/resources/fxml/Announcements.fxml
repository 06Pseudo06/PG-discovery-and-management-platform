<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.AnnouncementsController"
            stylesheets="@../css/owner-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="240" styleClass="owner-sidebar" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="logo-container">
                <StackPane styleClass="logo-icon-bg">
                    <Label text="🏠" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="PGFinder" styleClass="owner-logo"/>
                    <Label text="Owner Panel" styleClass="owner-subtitle"/>
                </VBox>
            </HBox>
            
            <Region prefHeight="20"/>
            
            <Button text="📁  Dashboard" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="🏢 My PGs" styleClass="owner-menu" maxWidth="Infinity" onAction="#openMyPGs"/>
            <Button text="🛏  Rooms &amp; Beds" styleClass="owner-menu" maxWidth="Infinity" onAction="#openRoomsBeds"/>
            <Button text="📢 Announcements" styleClass="owner-menu-active" maxWidth="Infinity"/>
            <Button text="💬 Chat" styleClass="owner-menu" maxWidth="Infinity" onAction="#openChat"/>
            <Button text="⭐ Reviews" styleClass="owner-menu" maxWidth="Infinity" onAction="#openReviews"/>
            <Button text="⚙ Settings" styleClass="owner-menu" maxWidth="Infinity" onAction="#openSettings"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="main-scrollpane">
            <VBox spacing="25" styleClass="owner-main-content">
                
                <VBox spacing="5">
                    <Label text="Announcements &amp; Notifications Manager" styleClass="page-title"/>
                    <Label text="Broadcast notices, rule changes, or payment updates to your hostel tenants." styleClass="stat-sublabel"/>
                </VBox>

                <HBox spacing="25">
                    <!-- LEFT: POST FORM -->
                    <VBox spacing="20" prefWidth="500">
                        <VBox styleClass="owner-large-card" spacing="15">
                            <Label text="Create Announcement" styleClass="section-title"/>
                            
                            <VBox spacing="6">
                                <Label text="Select Target PG Stay" styleClass="stat-label" style="-fx-font-weight: bold;"/>
                                <ComboBox fx:id="pgSelect" promptText="Choose PG Property" maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Announcement Title" styleClass="stat-label" style="-fx-font-weight: bold;"/>
                                <TextField fx:id="titleField" promptText="e.g., Rent Due Date Reminder"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Message Details" styleClass="stat-label" style="-fx-font-weight: bold;"/>
                                <TextArea fx:id="messageArea" promptText="Type details here..." prefRowCount="6" wrapText="true"/>
                            </VBox>

                            <HBox spacing="10">
                                <Button fx:id="submitBtn" text="Send Broadcast" styleClass="primary-button" onAction="#handlePostAnnouncement"/>
                                <Button fx:id="cancelEditBtn" text="Cancel Edit" visible="false" styleClass="secondary-button" onAction="#handleCancelEdit"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- RIGHT: LIVE RECIPIENT HISTORY FEED -->
                    <VBox spacing="15" HBox.hgrow="ALWAYS">
                        <Label text="Sent Announcement History" styleClass="section-title" style="-fx-text-fill: #FFFFFF;"/>
                        <VBox fx:id="announcementsHistoryContainer" spacing="15"/>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane> 