<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.StudentAnnouncementsController"
            stylesheets="@../css/student-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox fx:id="sidebar"
              prefWidth="250"
              spacing="15"
              styleClass="sidebar">

            <Label text="PG FINDER"
                   styleClass="logo"/>

            <VBox spacing="12"
                  alignment="CENTER"
                  styleClass="profile-card">
                <StackPane styleClass="avatar-circle">
                    <Label text="👨" styleClass="avatar-icon"/>
                </StackPane>
                <Label fx:id="profileNameLabel" text="Hi, Alex" styleClass="profile-name"/>
                <Label text="Welcome Back!" styleClass="profile-subtitle"/>
            </VBox>

            <Button text="🏠 Dashboard" styleClass="menu-button" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="🔍 Browse PGs" styleClass="menu-button" maxWidth="Infinity" onAction="#openBrowsePG"/>
            <Button text="📍 My Stay" styleClass="menu-button" maxWidth="Infinity" onAction="#openMyStay"/>
            <Button text="💬 Chat" styleClass="menu-button" maxWidth="Infinity" onAction="#openChat"/>
            <Button text="📢 Announcements" styleClass="menu-button, menu-button-active" maxWidth="Infinity"/>
            <Button text="📜 PG History" styleClass="menu-button" maxWidth="Infinity" onAction="#openPGHistory"/>
            <Button text="⭐ Reviews" styleClass="menu-button" maxWidth="Infinity" onAction="#openReviews"/>
            <Button text="⚙ Settings" styleClass="menu-button" maxWidth="Infinity" onAction="#openSettings"/>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="25" styleClass="main-content">
                
                <!-- HEADER -->
                <VBox spacing="5">
                    <Label text="Announcements" styleClass="heading"/>
                    <Label text="Important updates, maintenance, and rent alerts from your PG owner." styleClass="sub-heading"/>
                </VBox>

                <!-- SEARCH/FILTER ROW -->
                <VBox spacing="15" styleClass="content-card">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <TextField promptText="Search announcements..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
                        <ComboBox promptText="Filter by Priority" prefWidth="180"/>
                        <Button text="Search" styleClass="btn-primary" prefWidth="120"/>
                    </HBox>
                </VBox>

                <!-- ANNOUNCEMENTS LIST -->
                <VBox fx:id="announcementsContainer" spacing="20"/>

                <VBox spacing="10">
                    <Label text="Recent Notifications" styleClass="section-title"/>
                    <VBox fx:id="notificationsContainer" spacing="10" styleClass="content-card"/>
                </VBox>


            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
