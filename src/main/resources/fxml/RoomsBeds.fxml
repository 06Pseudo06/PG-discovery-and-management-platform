<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.RoomsBedsController"
            stylesheets="@../css/rooms-beds.css">

    <top>

        <HBox spacing="15"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <Button text="← My PGs"
                    onAction="#goBack"
                    styleClass="primary-button"/>

            <Label text="Rooms &amp; Beds"
                   styleClass="page-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="+ Add Room"
                    styleClass="primary-button"/>

        </HBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true">

            <VBox spacing="20"
                  styleClass="content-area">

                <!-- ROOM A -->

                <VBox spacing="15"
                      styleClass="room-card">

                    <HBox>

                        <Label text="Room A"
                               styleClass="room-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Edit Room"/>

                    </HBox>

                    <HBox spacing="25">

                        <Label text="Beds: 4"/>

                        <Label text="Occupied: 3"/>

                        <Label text="Vacant: 1"/>

                    </HBox>

                    <FlowPane hgap="10"
                              vgap="10">

                        <Label text="A1"
                               styleClass="bed-occupied"/>

                        <Label text="A2"
                               styleClass="bed-occupied"/>

                        <Label text="A3"
                               styleClass="bed-occupied"/>

                        <Label text="A4"
                               styleClass="bed-vacant"/>

                    </FlowPane>

                </VBox>

                <!-- ROOM B -->

                <VBox spacing="15"
                      styleClass="room-card">

                    <HBox>

                        <Label text="Room B"
                               styleClass="room-title"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Edit Room"/>

                    </HBox>

                    <HBox spacing="25">

                        <Label text="Beds: 4"/>

                        <Label text="Occupied: 2"/>

                        <Label text="Vacant: 2"/>

                    </HBox>

                    <FlowPane hgap="10"
                              vgap="10">

                        <Label text="B1"
                               styleClass="bed-occupied"/>

                        <Label text="B2"
                               styleClass="bed-occupied"/>

                        <Label text="B3"
                               styleClass="bed-vacant"/>

                        <Label text="B4"
                               styleClass="bed-vacant"/>

                    </FlowPane>

                </VBox>

            </VBox>

        </ScrollPane>

    </center>

</BorderPane>