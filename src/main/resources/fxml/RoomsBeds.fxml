<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.RoomsBedsController"
            stylesheets="@../css/owner-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="240" styleClass="owner-sidebar" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="logo-container">
                <StackPane styleClass="logo-icon-bg">
                    <Label text="🏠" styleClass="logo-icon"/>
                </StackPane>
                <VBox>
                    <Label text="PGFinder" styleClass="owner-logo"/>
                    <Label text="Owner Panel" styleClass="owner-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="20"/>

            <Button text="📁  Dashboard" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="🏢 My PGs" styleClass="owner-menu" maxWidth="Infinity" onAction="#openMyPGs"/>
            <Button text="🛏  Rooms &amp; Beds" styleClass="owner-menu-active" maxWidth="Infinity"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="📋  Requests" styleClass="owner-menu" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openBookingRequests"/>
                <Label text="5" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="👥  Tenants" styleClass="owner-menu" maxWidth="Infinity" onAction="#openTenants"/>
            <Button text="📢  Announcements" styleClass="owner-menu" maxWidth="Infinity" onAction="#openAnnouncements"/>
            
            <HBox alignment="CENTER_LEFT" styleClass="menu-item-with-badge">
                <Button text="💬  Chats" styleClass="owner-menu" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#openChat"/>
                <Label text="3" styleClass="menu-badge"/>
            </HBox>
            
            <Button text="⭐  Reviews" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="📊  Reports" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>
            <Button text="⚙  Settings" styleClass="owner-menu" maxWidth="Infinity" onAction="#openDashboard"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="↪  Logout" styleClass="logout-button" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- MAIN BODY -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scrollpane">
            <VBox spacing="25" styleClass="owner-main-content">
                
                <!-- TOP BAR NAVIGATION -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button text="← Back to My PGs" styleClass="secondary-button" onAction="#goBack"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS" style="-fx-padding: 0 0 0 10;"> 
                        <Label fx:id="pgTitleLabel" text="Rooms &amp; Beds" styleClass="page-title"/>
                        <Label fx:id="pgLocationLabel" text="" styleClass="welcome-subtitle" style="-fx-text-fill: #B2DBD4;"/>
                    </VBox>
                    <Button fx:id="createRoomButton" text="+ Create Room" styleClass="primary-button" onAction="#handleCreateRoom"/>
                </HBox>

                <!-- STATS COUNTER -->
                <HBox spacing="20">
                    <HBox styleClass="owner-stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container"><Label text="🛏" styleClass="stat-icon"/></StackPane>
                        <VBox>
                            <Label text="Total Beds Cap" styleClass="stat-label"/>
                            <Label fx:id="totalBedsLabel" text="0 Beds" styleClass="owner-stat-number" style="-fx-font-size: 20px;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="owner-stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container" style="-fx-background-color: #EEF7F4;"><Label text="👥" styleClass="stat-icon" style="-fx-text-fill: #0F4F46;"/></StackPane>
                        <VBox>
                            <Label text="Beds Occupied" styleClass="stat-label"/>
                            <Label fx:id="occupiedBedsLabel" text="0 Beds" styleClass="owner-stat-number" style="-fx-font-size: 20px;"/>
                        </VBox>
                    </HBox>
                    <HBox styleClass="owner-stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="stat-icon-container" style="-fx-background-color: #EBF5FF;"><Label text="🔑" styleClass="stat-icon" style="-fx-text-fill: #1E40AF;"/></StackPane>
                        <VBox>
                            <Label text="Vacant Spaces" styleClass="stat-label"/>
                            <Label fx:id="vacantBedsLabel" text="0 Beds" styleClass="owner-stat-number" style="-fx-font-size:20px; -fx-text-fill:#16A34A;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Dynamic Room Container -->

                <VBox fx:id="roomsContainer" spacing="20">
                    
                    <!-- Room A1 Details -->
                    <VBox spacing="15" styleClass="room-card">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3">
                                <Label text="Room A1 (Double Sharing)" styleClass="room-title"/>
                                <Label text="First Floor  •  Premium AC Room" styleClass="sub-heading" style="-fx-font-size: 12px;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Edit Room Details" styleClass="card-action-btn"/>
                        </HBox>
                        
                        <HBox spacing="40" style="-fx-padding: 5 0;">
                            <Label text="Beds: 2" style="-fx-font-weight: bold;"/>
                            <Label text="Occupied: 1" style="-fx-font-weight: bold;"/>
                            <Label text="Vacant: 1" style="-fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                        </HBox>
                        
                        <!-- Beds status visualizer -->
                        <VBox spacing="8">
                            <Label text="Bed Occupancy Plan" styleClass="stat-label"/>
                            <FlowPane hgap="12" vgap="12">
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-occupied" prefWidth="150">
                                    <Label text="🛏️" style="-fx-text-fill: #FFFFFF;"/>
                                    <Label text="Bed B1 (Rahul)" style="-fx-text-fill: #FFFFFF;"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-vacant" prefWidth="150">
                                    <Label text="🛏️"/>
                                    <Label text="Bed B2 (Vacant)"/>
                                </HBox>
                            </FlowPane>
                        </VBox>
                    </VBox>

                    <!-- Room A2 Details -->
                    <VBox spacing="15" styleClass="room-card">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3">
                                <Label text="Room A2 (Triple Sharing)" styleClass="room-title"/>
                                <Label text="First Floor  •  AC Room" styleClass="sub-heading" style="-fx-font-size: 12px;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Edit Room Details" styleClass="card-action-btn"/>
                        </HBox>
                        
                        <HBox spacing="40" style="-fx-padding: 5 0;">
                            <Label text="Beds: 3" style="-fx-font-weight: bold;"/>
                            <Label text="Occupied: 2" style="-fx-font-weight: bold;"/>
                            <Label text="Vacant: 1" style="-fx-font-weight: bold; -fx-text-fill: #16A34A;"/>
                        </HBox>
                        
                        <!-- Beds status visualizer -->
                        <VBox spacing="8">
                            <Label text="Bed Occupancy Plan" styleClass="stat-label"/>
                            <FlowPane hgap="12" vgap="12">
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-occupied" prefWidth="150">
                                    <Label text="🛏️" style="-fx-text-fill: #FFFFFF;"/>
                                    <Label text="Bed C1 (Aman)"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-occupied" prefWidth="150">
                                    <Label text="🛏️" style="-fx-text-fill: #FFFFFF;"/>
                                    <Label text="Bed C2 (Neha)"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-vacant" prefWidth="150">
                                    <Label text="🛏️"/>
                                    <Label text="Bed C3 (Vacant)"/>
                                </HBox>
                            </FlowPane>
                        </VBox>
                    </VBox>

                    <!-- Room A3 Details (Maintenance Example) -->
                    <VBox spacing="15" styleClass="room-card">
                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3">
                                <Label text="Room A3 (Double Sharing)" styleClass="room-title"/>
                                <Label text="Second Floor  •  Non-AC Room" styleClass="sub-heading" style="-fx-font-size: 12px;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Edit Room Details" styleClass="card-action-btn"/>
                        </HBox>
                        
                        <HBox spacing="40" style="-fx-padding: 5 0;">
                            <Label text="Beds: 3" style="-fx-font-weight: bold;"/>
                            <Label text="Occupied: 3" style="-fx-font-weight: bold;"/>
                            <Label text="Vacant: 0" style="-fx-font-weight: bold;"/>
                            <Label text="Maintenance: 1" style="-fx-font-weight: bold; -fx-text-fill: #DC2626;"/>
                        </HBox>
                        
                        <!-- Beds status visualizer -->
                        <VBox spacing="8">
                            <Label text="Bed Occupancy Plan" styleClass="stat-label"/>
                            <FlowPane hgap="12" vgap="12">
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-occupied" prefWidth="150">
                                    <Label text="🛏️" style="-fx-text-fill: #FFFFFF;"/>
                                    <Label text="Bed D1 (Vikram)"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-occupied" prefWidth="150">
                                    <Label text="🛏️" style="-fx-text-fill: #FFFFFF;"/>
                                    <Label text="Bed D2 (Pooja)"/>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bed-maintenance" prefWidth="150">
                                    <Label text="🛠️"/>
                                    <Label text="Bed D3 (Leakage)"/>
                                </HBox>
                            </FlowPane>
                        </VBox>
                    </VBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>