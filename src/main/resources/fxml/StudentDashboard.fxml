<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pgfinder.controller.StudentDashboardController"
            stylesheets="@../css/student-dashboard.css"
            prefWidth="1280" prefHeight="800">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox fx:id="sidebar"
              prefWidth="250"
              spacing="15"
              styleClass="sidebar">

            <Label text="PG FINDER"
                   styleClass="logo"/>

            <VBox spacing="12"
                  alignment="CENTER"
                  styleClass="profile-card">
                <StackPane styleClass="avatar-circle">
                    <Label text="👨" styleClass="avatar-icon"/>
                </StackPane>
                <Label fx:id="profileNameLabel" text="Hi, Alex" styleClass="profile-name"/>
                <Label text="Welcome Back!" styleClass="profile-subtitle"/>
            </VBox>

            <Button text="🏠 Dashboard" styleClass="menu-button, menu-button-active" maxWidth="Infinity"/>
            <Button text="🔍 Browse PGs" styleClass="menu-button" maxWidth="Infinity" onAction="#openBrowsePG"/>
            <Button text="📍 My Stay" styleClass="menu-button" maxWidth="Infinity" onAction="#openMyStay"/>
            <Button text="💬 Chat" styleClass="menu-button" maxWidth="Infinity" onAction="#openChat"/>
            <Button text="📢 Announcements" styleClass="menu-button" maxWidth="Infinity" onAction="#openAnnouncements"/>
            <Button text="📜 PG History" styleClass="menu-button" maxWidth="Infinity" onAction="#openPGHistory"/>
            <Button text="⭐ Reviews" styleClass="menu-button" maxWidth="Infinity" onAction="#openReviews"/>
            <Button text="⚙ Settings" styleClass="menu-button" maxWidth="Infinity" onAction="#openSettings"/>

        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox spacing="25" styleClass="main-content">

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="greetingLabel" text="Good Morning, Alex! ☀️" styleClass="heading"/>
                        <Label text="Here is a quick overview of your accommodation activity." styleClass="sub-heading"/>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="notificationButton" text="🔔" styleClass="btn-secondary" style="-fx-padding: 10 12;" onAction="#openNotifications"/>
                        <Button text="👤 Settings" styleClass="btn-outline" onAction="#openSettings"/>
                    </HBox>
                </HBox>

                <!-- TOP QUICK STAT CARDS -->
                <GridPane hgap="20" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>
                    
                    <VBox styleClass="stat-card-yellow" GridPane.columnIndex="0">
                        <Label text="Current Stay"/>
                        <Label fx:id="currentStayLabel" text="No active stay" styleClass="card-number" style="-fx-font-size: 20px;"/>
                    </VBox>

                    <VBox styleClass="stat-card-green" GridPane.columnIndex="1">
                        <Label text="Days Remaining"/>
                        <Label text="147 Days" styleClass="card-number"/>
                    </VBox>

                    <VBox styleClass="stat-card-light" GridPane.columnIndex="2">
                        <Label text="Room &amp; Bed"/>
                        <Label fx:id="roomBedLabel" text="—" styleClass="card-number"/>
                    </VBox>

                    <VBox styleClass="stat-card-light" GridPane.columnIndex="3">
                        <Label text="Pending Invoices"/>
                        <Label text="₹0 (Paid)" styleClass="card-number" style="-fx-text-fill: #16A34A;"/>
                    </VBox>
                </GridPane>

                <!-- ROW 2: ACTIVE STAY & ANNOUNCEMENTS -->
                <HBox spacing="25">
                    
                    <!-- Current Stay Details -->
                    <VBox styleClass="content-card" HBox.hgrow="ALWAYS" prefWidth="600" spacing="20">
                        <Label text="Active Accommodation Summary" styleClass="section-title"/>
                        
                        <HBox spacing="20">
                            <StackPane styleClass="room-image" style="-fx-background-color: #DFF1EA; -fx-min-width: 200px; -fx-min-height: 130px;">
                                <Label text="Sunrise PG" styleClass="pg-title" style="-fx-font-size: 16px; -fx-text-fill: #214F4B;"/>
                            </StackPane>
                            
                            <VBox spacing="6">
                                <Label fx:id="activePgLabel" text="—" styleClass="pg-name" style="-fx-font-size: 20px;"/>
                                <Label text="📍 Model Town, Jalandhar" styleClass="sub-heading"/>
                                <Label text="🛏 Room A1 • Bed B2 (Double Sharing)" style="-fx-font-weight: bold;"/>
                                <Separator style="-fx-padding: 5 0;"/>
                                <Label fx:id="moveInLabel" text="—" styleClass="sub-heading"/>
                                <Label text="Move Out: 15 Jun 2027" styleClass="sub-heading"/>
                            </VBox>
                        </HBox>

                        <Separator/>
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Contract Duration Progress" styleClass="sub-heading" style="-fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="65% Completed" styleClass="sub-heading"/>
                            </HBox>
                            <ProgressBar progress="0.65" prefWidth="600"/>
                        </VBox>
                    </VBox>

                    <!-- Latest Announcements -->
                    <VBox styleClass="content-card" prefWidth="480" spacing="15">
                        <Label text="Latest Hostels Announcements" styleClass="section-title"/>
                        
                        <VBox fx:id="notificationsPreviewBox" spacing="10"/>
                    </VBox>

                </HBox>

                <!-- ROW 3: CHAT, HISTORY & RECOMMENDATIONS -->
                <HBox spacing="25">
                    
                    <!-- Quick Chat with Owner -->
                    <VBox styleClass="content-card" spacing="15" prefWidth="350">
                        <Label text="Chat with Owner" styleClass="section-title"/>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <StackPane styleClass="mini-avatar">
                                <Label text="👨"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Mr. Rohit Sharma" styleClass="chat-name"/>
                                <Label text="Owner: Technician will visit today." style="-fx-text-fill: #4B5563; -fx-font-size: 12px;"/>
                                <Label text="10:30 AM" styleClass="chat-time"/>
                            </VBox>
                        </HBox>
                        <Separator/>
                        <Button text="Open Conversation" styleClass="btn-outline" maxWidth="Infinity" onAction="#openChat"/>
                    </VBox>

                    <!-- Mini Stay History -->
                    <VBox styleClass="content-card" spacing="15" prefWidth="350">
                        <Label text="My Accommodation Stays" styleClass="section-title"/>
                        <VBox spacing="10">
                            <Label text="● Sunrise PG (Current Stay)" style="-fx-font-weight: bold; -fx-text-fill: #214F4B;"/>
                            <Label text="● Comfort Living Hostel (2025-2026)" style="-fx-text-fill: #4B5563;"/>
                            <Label text="● Student Nest Hostel (2024-2025)" style="-fx-text-fill: #4B5563;"/>
                        </VBox>
                        <Separator/>
                        <Button text="View Complete Timeline" styleClass="btn-secondary" maxWidth="Infinity" onAction="#openPGHistory"/>
                    </VBox>

                    <!-- Recommended PGs -->
                    <VBox styleClass="content-card" spacing="15" HBox.hgrow="ALWAYS">
                        <Label text="Recommended Accommodations" styleClass="section-title"/>
                        <VBox spacing="10">
                            
                            <HBox styleClass="recommendation-card" spacing="10" alignment="CENTER_LEFT" onMouseClicked="#openBrowsePG" style="-fx-cursor: hand;">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Green Residency" style="-fx-font-weight: bold;"/>
                                    <Label text="📍 Urban Estate  •  Boys PG" styleClass="sub-heading" style="-fx-font-size: 11px;"/>
                                </VBox>
                                <Label text="₹7,000/mo" style="-fx-font-weight: 800; -fx-text-fill: #214F4B;"/>
                            </HBox>

                            <HBox styleClass="recommendation-card" spacing="10" alignment="CENTER_LEFT" onMouseClicked="#openBrowsePG" style="-fx-cursor: hand;">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Student Hub" style="-fx-font-weight: bold;"/>
                                    <Label text="📍 University Road  •  Girls PG" styleClass="sub-heading" style="-fx-font-size: 11px;"/>
                                </VBox>
                                <Label text="₹6,200/mo" style="-fx-font-weight: 800; -fx-text-fill: #214F4B;"/>
                            </HBox>

                        </VBox>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>